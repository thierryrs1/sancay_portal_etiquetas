<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    controllerName="sps.wms.controller.filaimpressao"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
    xmlns:t="sap.ui.table">
  <Page
      id="pageView"
      busyIndicatorDelay="0"
      showHeader="true"
      title="Status das Impressoras"
      showFooter="false"
      showNavButton="true"
      enableScrolling="false"
      navButtonPress="onBack">
    <headerContent>
      <Toolbar class="sapMTBHeader-CTX">
        <Button
            text="Sair"
            type="Up"
            icon="sap-icon://log"
            iconFirst="true"
            width="auto"
            enabled="true"
            visible="true"
            press="onLogout" />
      </Toolbar>
    </headerContent>
    <VBox fitContainer="true" height="100%">
      <Toolbar class="sapUiSmallMarginTop sapUiSmallMarginBegin sapUiSmallMarginEnd">
        <Title text="Impressoras Instaladas no Servidor" level="H2" />
        <ToolbarSpacer />
        <Button icon="sap-icon://sys-monitor" text="Reiniciar Spooler" press="onRestartSpooler" type="Emphasized" />
        <Button icon="sap-icon://refresh" text="Atualizar" press="carregaDados" />
      </Toolbar>
      
      <t:Table
          id="tblList"
          rows="{Data>/Items}"
          selectionMode="None"
          visibleRowCountMode="Auto"
          class="sapUiSmallMargin">
        <t:layoutData>
          <FlexItemData growFactor="1" />
        </t:layoutData>
        <t:columns>
          <t:Column width="20rem" sortProperty="Name" filterProperty="Name">
            <Label text="Nome da Impressora" />
            <t:template>
              <Text text="{Data>Name}" />
            </t:template>
          </t:Column>
          <t:Column width="18rem" sortProperty="PrinterStatus">
            <Label text="Status da Impressora" />
            <t:template>
              <ObjectStatus text="{ path: 'Data>PrinterStatus', formatter: '.formatter.statusText' }" state="{ path: 'Data>PrinterStatus', formatter: '.formatter.statusState' }" />
            </t:template>
          </t:Column>
          <t:Column width="10rem" sortProperty="JobCount">
            <Label text="Documentos na Fila" />
            <t:template>
              <ObjectStatus text="{Data>JobCount}" state="{= ${Data>JobCount} === 0 ? 'Success' : (${Data>JobCount} > 10 ? 'Error' : 'Warning') }" />
            </t:template>
          </t:Column>
          <t:Column width="12rem" hAlign="Center">
            <Label text="Ações" />
            <t:template>
              <Button icon="sap-icon://delete" text="Limpar Fila" type="Reject" press="onClearQueue" enabled="{= ${Data>JobCount} > 0 }" />
            </t:template>
          </t:Column>
        </t:columns>
      </t:Table>
    </VBox>
  </Page>
</mvc:View>
