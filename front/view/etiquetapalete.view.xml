<mvc:View
  xmlns:mvc="sap.ui.core.mvc"
  controllerName="sps.wms.controller.etiquetapalete"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:data="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
  xmlns:layout="sap.ui.layout"
  xmlns:f="sap.ui.layout.form"
  xmlns:t="sap.ui.table"
>
  <Page
    id="pageView"
    busyIndicatorDelay="0"
    showHeader="true"
    title="Impressão Etiqueta Palete : {Data>/CompanyName}"
    showFooter="true"
    showNavButton="true"
    navButtonPress="onBack"
  >
    <headerContent>
      <Toolbar class="sapMTBHeader-CTX">
        <Button text="Sair" type="Up" icon="sap-icon://log" iconFirst="true" width="auto" enabled="true" visible="true" press="onLogout"/>
      </Toolbar>
    </headerContent>
    <t:Table
        id="tblList"
        rows="{Data>/Items}"
        selectionMode="MultiToggle"
        selectionBehavior="RowSelector"
        alternateRowColors="true"
        enableColumnReordering="true"
        visibleRowCountMode="Auto"
        width="100%"
        enableCellFilter="true"
        rowHeight="40"
        rowSelectionChange="onRowSelectionChange"
        >
      <t:extension>
        <f:SimpleForm 
                    editable="true"
                    layout="ResponsiveGridLayout"
                    labelSpanL="4"
                    labelSpanM="4"
                    adjustLabelSpan="false"
                    emptySpanL="2"
                    emptySpanM="0"
                    columnsL="2"
                    columnsM="2"
                    singleContainerFullSize="true" >
          <f:content>
            <core:Title text="Parâmetros de Consulta"/>
            <Label text="Data Criação de" />
            <DatePicker 
                            value="{Data>/DataIni}" 
                            valueFormat="yyyy-MM-dd"/>
            <Label text="Data Criação até" />
            <DatePicker 
                            value="{Data>/DataFin}" 
                            valueFormat="yyyy-MM-dd"/>
            <Label text="Palete" />
            <Input value="{Data>/Palete}" />
            <Label text="Inclui Vazios" />
            <Select 
                            forceSelection="true"
                            selectedKey="{Data>/Vazios}"
                            maxWidth="30rem"
                            items="{Data>/YesNo}">
              <core:Item key="{Data>key}" text="{Data>text}" />
            </Select>
          
            <core:Title/>
                       
            <Label text="" />
            <HBox>
              <Button 
                            text="Filtrar" 
                            class="sapUiTinyMarginEnd"
                            width="125px"
                            press="onFilter" />
              <Button 
                            text="Limpar" 
                            class="sapUiTinyMarginEnd"
                            width="125px"
                            press="onClearForm" />
            </HBox>
 
<core:Title text="Parâmetros de Impressão"/>
            <Label text="Impressora Palete"/>
            <Select
                            forceSelection="false"
                            selectedKey="{Data>/ImpressoraPalete}"
                            maxWidth="30rem"
                            items="{
                                path: 'ImpressorasPalete>/Items'
                            }">
              <core:Item key="{ImpressorasPalete>Impressora}" text="{ImpressorasPalete>Impressora}" />
            </Select>
          </f:content>
        </f:SimpleForm>
      </t:extension>
      <t:columns></t:columns>
    </t:Table>
    <footer>
      <OverflowToolbar width="100%" >
        <content>
          <ToolbarSpacer />
          <Button text="Imprimir" press="onPrintPressed" type="Accept" icon="sap-icon://print"/>
        </content>
      </OverflowToolbar>
    </footer>
  </Page>
</mvc:View>