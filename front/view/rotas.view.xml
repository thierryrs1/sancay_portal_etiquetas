<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    controllerName="sps.wms.controller.rotas"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:data="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
    xmlns:t="sap.ui.table">
  <Page
      id="pageView"
      busyIndicatorDelay="0"
      showHeader="true"
      title="Usuário x Depósito : {Data>/CompanyName}"
      showFooter="true"
      showNavButton="true"
      navButtonPress="onBack">
    <headerContent>
      <Toolbar class="sapMTBHeader-CTX">
        <Button
            text="Sair"
            type="Up"
            icon="sap-icon://log"
            iconFirst="true"
            width="auto"
            enabled="true"
            visible="true"
            press="onLogout" />
      </Toolbar>
    </headerContent>
    <l:Grid
        class="sapUiSmallMarginTop"
        containerQuery="true">
        <VBox class="sapUiMediumMarginBeginEnd">
          <layoutData>
            <l:GridData span="XL2 L2 M2 S2"/>
          </layoutData></VBox>
        <VBox class="sapUiMediumMarginBeginEnd" height="100%">
          <layoutData>
            <l:GridData span="XL8 L8 M8 S8"/>
          </layoutData>
      <t:Table
          id="tblList"
          class="sapUiSmallMarginBeginEnd"
          rows="{Data>/list}"
          selectionMode="None"
          selectionBehavior="RowSelector"
          alternateRowColors="true"
          enableColumnReordering="true"
          visibleRowCount="10"
          width="100%"
          enableCellFilter="true"
          rowHeight="40"
          rowSelectionChange="onRowSelectionChange">
        <t:extension>
          <HBox
              alignContent="Center"
              alignItems="Center">
            <Label
                text="Rota"
                class="sapUiSmallMarginBeginEnd" />
            <Select
                class="sapUiSmallMarginEnd"
                width="10rem"
                selectedKey="{Data>/rotaDocEntry}"
                items="{Rotas>/list}"
                change="carregaRota">
              <core:Item
                  key="{Rotas>DocEntry}"
                  text="{Rotas>RotaTxt}" />
            </Select>

            <Button
                class="sapUiSmallMarginEnd"
                icon="sap-icon://create"
                text="Nova Rota"
                press="adicionaRota" />

            <Button
                class="sapUiSmallMarginEnd"
                icon="sap-icon://delete"
                text="Remove Rota"
                press="removeRota" />

          </HBox>
        </t:extension>
        <t:columns>
          <t:Column>
            <Label
                text="Dep Origem"
                textAlign="Left"
                width="100%" />
            <t:template>
              <HBox>
                <Button
                    icon="sap-icon://add"
                    press="addLine"
                    visible="{= ${Data>U_WhsCode_Origem}===null}" />
                <Select
                    forceSelection="false"
                    selectedKey="{Data>U_WhsCode_Origem}"
                    visible="{= ${Data>U_WhsCode_Origem}!==null}"
                    width="10rem"
                    maxWidth="30rem"
                    items="{
                      path: 'Depositos>/list',
                      templateShareable: true
                  }">
                  <core:Item
                      key="{Depositos>WhsCode}"
                      text="{Depositos>WhsCode}" />
                </Select>
              </HBox>
            </t:template>
          </t:Column>
          <t:Column>
            <Label
                text="Dep Destino"
                textAlign="Left"
                width="100%" />
            <t:template>
              <Select
                  forceSelection="false"
                  selectedKey="{Data>U_WhsCode_Destino}"
                  visible="{= ${Data>U_WhsCode_Origem}!==null}"
                  width="10rem"
                  maxWidth="30rem"
                  items="{
                    path: 'Depositos>/list',
                    templateShareable: true
                }">
                <core:Item
                    key="{Depositos>WhsCode}"
                    text="{Depositos>WhsCode}" />
              </Select>
            </t:template>
          </t:Column>
          <t:Column width="3%">
            <t:template>
              <Button
                  icon="sap-icon://delete"
                  press="deleteLine"
                  visible="{= ${Data>U_WhsCode_Origem}!==null}" />
            </t:template>
          </t:Column>
        </t:columns>
      </t:Table>
      <VBox class="sapUiMediumMarginBeginEnd">
        <layoutData>
          <l:GridData span="XL2 L2 M2 S2"/>
        </layoutData></VBox>
      </VBox>
    </l:Grid>
    <footer>
      <OverflowToolbar width="100%">
        <content>
          <ToolbarSpacer />
          <Button
              text="Gravar"
              press="onSavePressed"
              type="Accept"
              icon="sap-icon://save" />
        </content>
      </OverflowToolbar>
    </footer>
  </Page>
</mvc:View>