<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    controllerName="sps.wms.controller.configuraimpressao"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:data="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
    xmlns:l="sap.ui.layout"
    xmlns:t="sap.ui.table">
  <Page
      id="pageView"
      busyIndicatorDelay="0"
      showHeader="true"
      title="Configura Impressão : {Data>/CompanyName}"
      showFooter="true"
      showNavButton="true"
      navButtonPress="onBack">
    <headerContent>
      <Toolbar class="sapMTBHeader-CTX">
        <Button
            text="Sair"
            type="Up"
            icon="sap-icon://log"
            iconFirst="true"
            width="auto"
            enabled="true"
            visible="true"
            press="onLogout" />
      </Toolbar>
    </headerContent>
    <HBox class="sapUiSmallMargin">
      <t:Table
          id="tblTipoEtq"
          rows="{TipoEtq>/list}"
          selectionMode="Single"
          selectionBehavior="Row"
          rowSelectionChange="tipoEtqSelected"
          alternateRowColors="true"
          visibleRowCount="12"
          width="100%"
          rowHeight="48">
          <t:layoutData>
            <FlexItemData growFactor="8" />
          </t:layoutData>
          <t:extension>
            <OverflowToolbar>
              <Title text="Tipos Etiquetas" />
              <ToolbarSpacer />
              <Button icon="sap-icon://world" text="Idiomas" press="onIdiomasPressed" />
              <Button icon="sap-icon://list" text="Configurar Dropdowns" press="onConfigurarTags" enabled="{= ${TipoEtq>/list}.length > 0 }" />
            </OverflowToolbar>
          </t:extension>
        <t:columns>
          <t:Column width="15rem">
            <Label
                text="Tipo"
                textAlign="Left"
                width="100%" />
            <t:template>
              <HBox>
                <Button
                    icon="sap-icon://add"
                    press="addTipoEtq"
                    visible="{= ${TipoEtq>tipoEtq}===null}" />
                <Input
                    width="100%"
                    visible="{= ${TipoEtq>tipoEtq}!==null}"
                    value="{TipoEtq>tipoEtq}" />
              </HBox>
            </t:template>
          </t:Column>
          <t:Column width="5rem">
            <Link
                text="Ícone"
                href="https://ui5.sap.com/test-resources/sap/m/demokit/iconExplorer/webapp/index.html#"
                target="_blank"
                width="100%" />
            <t:template>
              <HBox alignContent="Center" alignItems="Center">
                <Button
                    icon="{= ${TipoEtq>icon} ? ${TipoEtq>icon} : 'sap-icon://image-viewer' }"
                    type="Transparent"
                    visible="{= ${TipoEtq>tipoEtq}!==null}"
                    press="onOpenIconModal" />
              </HBox>
            </t:template>
          </t:Column>
          <t:Column width="5rem">
            <Label text="Manual?" />
            <t:template>
              <CheckBox
                  selected="{= ${TipoEtq>isManual} === 'Y' }"
                  select="onManualSelect"
                  visible="{= ${TipoEtq>tipoEtq}!==null}" />
            </t:template>
          </t:Column>
          <t:Column width="6rem">
            <Label text="Volume?" />
            <t:template>
              <CheckBox
                  selected="{= ${TipoEtq>controlaVolume} === 'Y' }"
                  select="onControlaVolumeSelect"
                  visible="{= ${TipoEtq>tipoEtq}!==null}" />
            </t:template>
          </t:Column>
          <t:Column width="6rem">
            <Label text="Idioma?" />
            <t:template>
              <CheckBox
                  selected="{= ${TipoEtq>controlaIdioma} === 'Y' }"
                  select="onControlaIdiomaSelect"
                  visible="{= ${TipoEtq>tipoEtq}!==null}" />
            </t:template>
          </t:Column>
          <t:Column width="8rem">
            <Label
                text="PRN"
                textAlign="Left"
                width="100%" />
            <t:template>
              <HBox alignContent="Center" alignItems="Center">
                <Button
                    icon="sap-icon://edit"
                    type="Transparent"
                    visible="{= ${TipoEtq>tipoEtq}!==null}"
                    press="onOpenPrnModal" />
              </HBox>
            </t:template>
          </t:Column>
          <t:Column width="20rem">
            <Label
                text="Procedure"
                textAlign="Left"
                width="100%" />
            <t:template>
              <Select
                  forceSelection="true"
                  selectedKey="{TipoEtq>procedure}"
                  visible="{= ${TipoEtq>tipoEtq}!==null}"
                  width="100%"
                  items="{
                    path: 'Procedures>/list',
                    templateShareable: true
                }">
                <core:Item
                    key="{Procedures>procedure}"
                    text="{Procedures>procedure}" />
              </Select>
            </t:template>
          </t:Column>
          <t:Column width="3rem">
            <t:template>
              <Button
                  icon="sap-icon://delete"
                  press="deleteTipoEtq"
                  visible="{= ${TipoEtq>tipoEtq}!==null}" />
            </t:template>
          </t:Column>
        </t:columns>
      </t:Table>
      <Label class="sapUiMediumMargin" />
      <t:Table
          id="tblTipoImp"
          rows="{TipoImp>/list}"
          selectionMode="None"
          alternateRowColors="true"
          visibleRowCount="12"
          width="100%"
          rowHeight="48">
        <t:layoutData>
          <FlexItemData growFactor="2" />
        </t:layoutData>
        <t:extension>
          <OverflowToolbar>
            <Title text="Tipo x Impressoras" />
          </OverflowToolbar>
        </t:extension>
        <t:columns>
          <t:Column width="12rem">
            <Label
                text="Tipo"
                textAlign="Left"
                width="100%" />
            <t:template>
              <HBox>
                <Button
                    icon="sap-icon://add"
                    press="addTipoImp"
                    visible="{= ${TipoImp>tipoEtq}===null}" />
                <Label
                    visible="{= ${TipoImp>tipoEtq}!==null}"
                    text="{TipoImp>tipoEtq}" />
              </HBox>
            </t:template>
          </t:Column>
          <t:Column>
            <Label
                text="Impressora"
                textAlign="Left"
                width="100%" />
            <t:template>
              <Select
                  forceSelection="true"
                  selectedKey="{TipoImp>impressora}"
                  visible="{= ${TipoImp>tipoEtq}!==null}"
                  width="100%"
                  items="{
                    path: 'Impressoras>/list',
                    templateShareable: true
                }">
                <core:Item
                    key="{Impressoras>name}"
                    text="{Impressoras>name}" />
              </Select>
            </t:template>
          </t:Column>
          <t:Column width="6rem">
            <Label
                text="Padrão"
                textAlign="Left"
                width="100%" />
            <t:template>
              <CheckBox
                  selected="{TipoImp>defaultChk}"
                  visible="{= ${TipoImp>tipoEtq}!==null}" />
            </t:template>
          </t:Column>
          <t:Column width="3rem">
            <t:template>
              <Button
                  icon="sap-icon://delete"
                  press="deleteTipoImp"
                  visible="{= ${TipoImp>tipoEtq}!==null}" />
            </t:template>
          </t:Column>
        </t:columns>
      </t:Table>
    </HBox>
	<Button
      text="Edita Regras"
      type="Default"
      icon="sap-icon://edit"
      press="onEditaRegraPressed" 
      class="sapUiSmallMargin"/>	   
    <footer>
      <OverflowToolbar width="100%">
        <content>
          <ToolbarSpacer />
          <Button
              text="Gravar"
              press="onSavePressed"
              type="Accept"
              icon="sap-icon://save" />
        </content>
      </OverflowToolbar>
    </footer>
    <dependents>
      <Dialog id="iconDialog" title="Código do Ícone" contentWidth="400px" verticalScrolling="false" resizable="false" draggable="true">
        <content>
          <HBox class="sapUiSmallMargin" alignItems="Center" width="auto">
            <core:Icon 
                src="{= ${TipoEtq>icon} ? ${TipoEtq>icon} : 'sap-icon://image-viewer' }" 
                size="2rem" 
                class="sapUiMediumMarginEnd" />
            <Input 
                value="{TipoEtq>icon}" 
                width="100%" 
                placeholder="ex: sap-icon://print">
              <layoutData>
                <FlexItemData growFactor="1" />
              </layoutData>
            </Input>
          </HBox>
        </content>
        <beginButton>
          <Button text="Concluir" type="Emphasized" press="onCloseIconModal" />
        </beginButton>
      </Dialog>
      
      <Dialog id="prnDialog" title="Código PRN" stretch="true" contentWidth="800px" contentHeight="600px" verticalScrolling="true" resizable="true" draggable="true">
        <content>
          <TextArea 
              value="{TipoEtq>pathPrn}" 
              width="100%" 
              height="100%" 
              rows="30"
              placeholder="Cole o código PRN (ZPL) aqui..." />
        </content>
        <beginButton>
          <Button text="Concluir" type="Emphasized" press="onClosePrnModal" />
        </beginButton>
      </Dialog>
      
      <Dialog id="tagsDialog" title="Configurar Dropdowns: {ConfigTags>/TipoEtqSelecionado}" stretch="true" contentWidth="800px" contentHeight="600px" verticalScrolling="true" resizable="true" draggable="true">
        <content>
          <t:Table
              rows="{ConfigTags>/list}"
              selectionMode="None"
              alternateRowColors="true"
              visibleRowCount="10"
              width="100%"
              rowHeight="48">
            <t:columns>
              <t:Column width="15rem">
                <Label text="Tag (Variável do PRN)" />
                <t:template>
                  <Text text="{ConfigTags>tag}" />
                </t:template>
              </t:Column>
              <t:Column>
                <Label text="Consulta SQL (Retornar colunas 'Key' e 'Text')" />
                <t:template>
                  <Input value="{ConfigTags>consulta}" placeholder="Ex: SELECT id AS &quot;Key&quot;, nome AS &quot;Text&quot; FROM MINHA_TAB" />
                </t:template>
              </t:Column>
            </t:columns>
          </t:Table>
        </content>
        <beginButton>
          <Button text="Salvar" type="Accept" press="onSaveTags" />
        </beginButton>
        <endButton>
          <Button text="Cancelar" type="Reject" press="onCloseTagsDialog" />
        </endButton>
      </Dialog>
    </dependents>
  </Page>
</mvc:View>