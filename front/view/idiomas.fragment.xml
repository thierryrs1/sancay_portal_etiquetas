<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:t="sap.ui.table">
  <Dialog title="Configuração de Idiomas" contentHeight="60%" contentWidth="40%" resizable="true">
    <t:Table
        id="tblIdiomas"
        rows="{Idiomas>/list}"
        selectionMode="None"
        visibleRowCount="8"
        width="100%">
      <t:extension>
        <OverflowToolbar>
          <ToolbarSpacer />
          <Button icon="sap-icon://add" text="Adicionar" press="onAddIdioma" />
        </OverflowToolbar>
      </t:extension>
      <t:columns>
        <t:Column width="8rem">
          <Label text="Sigla" />
          <t:template>
            <Input value="{Idiomas>sigla}" />
          </t:template>
        </t:Column>
        <t:Column>
          <Label text="Descrição" />
          <t:template>
            <Input value="{Idiomas>descricao}" />
          </t:template>
        </t:Column>
        <t:Column width="3rem">
          <t:template>
            <Button icon="sap-icon://delete" type="Transparent" press="onDeleteIdioma" />
          </t:template>
        </t:Column>
      </t:columns>
    </t:Table>
    <buttons>
      <Button text="Gravar" press="onGravarIdiomas" type="Accept" icon="sap-icon://save" />
      <Button text="Cancelar" press="onCancelarIdiomas" type="Reject" icon="sap-icon://cancel" />
    </buttons>
  </Dialog>
</core:FragmentDefinition>
