<mvc:View
  xmlns:mvc="sap.ui.core.mvc"
  controllerName="sps.wms.controller.cancelapicking"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:data="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
  xmlns:layout="sap.ui.layout"
  xmlns:f="sap.ui.layout.form"
  xmlns:t="sap.ui.table"
>
  <Page
    id="pageView"
    busyIndicatorDelay="0"
    showHeader="true"
    title="Pickings : {Data>/CompanyName}"
    showFooter="true"
    showNavButton="true"
    navButtonPress="onBack"
  >
    <headerContent>
      <Toolbar class="sapMTBHeader-CTX">
        <Button text="Sair" type="Up" icon="sap-icon://log" iconFirst="true" width="auto" enabled="true" visible="true" press="onLogout"/>
      </Toolbar>
    </headerContent>
    <t:Table
        id="tblList"
        rows="{Data>/Items}"
        selectionMode="MultiToggle"
        selectionBehavior="RowSelector"
        alternateRowColors="true"
        enableColumnReordering="true"
        visibleRowCountMode="Auto"
        width="100%"
        enableCellFilter="true"
        rowHeight="45"
        rowSelectionChange="onRowSelectionChange"
        >
      <t:columns></t:columns>
    </t:Table>
    <footer>
      <OverflowToolbar width="100%" >
        <content>
          <ToolbarSpacer />
          <Button text="Cancelar" press="onCancelarPressed" type="Reject" icon="sap-icon://delete"/>
        </content>
      </OverflowToolbar>
    </footer>
  </Page>
</mvc:View>