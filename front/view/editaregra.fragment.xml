<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:data="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
>
  <Dialog title="Function de Regra de Tipo de Impressão: FN_SPS_ETIQ_REGRA"
    contentHeight="100%"
    contentWidth="100%">
    <VBox class="sapUiSmallMargin" height="100%">
      <Panel expandable="true" headerText="Cabeçalho" width="auto" class="sapUiResponsiveMargin">
        <content>
          <TextArea
            value="{regraFn>/header}"
            width="100%"
            growing="true"
            editable="false" />
        </content>
      </Panel>
      <Panel expandable="true" headerText="Regras (IF..ELSE)" width="auto" class="sapUiResponsiveMargin">
        <content>
          <TextArea
            value="{regraFn>/cases}"
            width="100%"
            growing="true"
            editable="true" />
        </content>
      </Panel>
      <Panel expandable="true" headerText="FIM" width="auto" class="sapUiResponsiveMargin">
        <content>
          <TextArea
            value="{regraFn>/joins}"
            width="100%"
            growing="true"
            editable="false" />
        </content>
      </Panel>
    </VBox>
    <buttons>
      <Button
        text="Gravar"
        press="onGravarSpPressed"
        type="Accept"
        icon="sap-icon://save" />
      <Button
        text="Cancelar"
        press="onCancelarSpPressed"
        type="Reject"
        icon="sap-icon://cancel" />

    </buttons>
  </Dialog>
</core:FragmentDefinition>