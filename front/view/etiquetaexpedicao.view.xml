<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    controllerName="sps.wms.controller.etiquetaexpedicao"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:data="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
    xmlns:layout="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
    xmlns:t="sap.ui.table">
  <Page
      id="pageView"
      busyIndicatorDelay="0"
      showHeader="true"
      title="Impressão Etiqueta Expedição : {Data>/CompanyName}"
      showFooter="true"
      showNavButton="true"
      navButtonPress="onBack">
    <headerContent>
      <Toolbar class="sapMTBHeader-CTX">
        <Button
            text="Sair"
            type="Up"
            icon="sap-icon://log"
            iconFirst="true"
            width="auto"
            enabled="true"
            visible="true"
            press="onLogout" />
      </Toolbar>
    </headerContent>
    <t:Table
        id="tblList"
        rows="{Data>/Items}"
        selectionMode="MultiToggle"
        selectionBehavior="RowSelector"
        alternateRowColors="true"
        enableColumnReordering="true"
        visibleRowCountMode="Auto"
        width="100%"
        enableCellFilter="true"
        rowHeight="40"
        rowSelectionChange="onRowSelectionChange">
      <t:extension>
        <f:SimpleForm
            editable="true"
            layout="ResponsiveGridLayout"
            labelSpanL="4"
            labelSpanM="4"
            adjustLabelSpan="false"
            emptySpanL="2"
            emptySpanM="0"
            columnsL="2"
            columnsM="2"
            singleContainerFullSize="true">
          <f:content>
            <core:Title text="Parâmetros de Consulta" />
            <Label text="Data Documento de" />
            <DatePicker
                value="{Data>/dataIni}"
                valueFormat="yyyy-MM-dd" />
            <Label text="Data Documento até" />
            <DatePicker
                value="{Data>/dataFin}"
                valueFormat="yyyy-MM-dd" />


            <core:Title />
            <Label text="Tipo Documento" />

            <Select
                forceSelection="true"
                selectedKey="{Data>/objType}"
                width="100%"
                items="{TipoDocs>/items}">
              <core:Item
                  key="{TipoDocs>objType}"
                  text="{TipoDocs>docName}" />
            </Select>

            <Label text="Documento" />
            <Input
                value="{Data>/docNum}"
                type="Number" />

            <Label text="" />
            <HBox>
              <Button
                  text="Filtrar"
                  class="sapUiTinyMarginEnd"
                  width="125px"
                  press="onFilter" />
              <Button
                  text="Limpar"
                  class="sapUiTinyMarginEnd"
                  width="125px"
                  press="onClearForm" />
            </HBox>
            <core:Title />
            <Label text="Impressora" />
            <Select
                forceSelection="false"
                selectedKey="{Data>/Impressora}"
                maxWidth="30rem"
                items="{
                                path: 'Impressoras>/Items'
                            }">
              <core:Item
                  key="{Impressoras>Impressora}"
                  text="{Impressoras>Impressora}" />
            </Select>
          </f:content>
        </f:SimpleForm>
      </t:extension>
      <t:columns></t:columns>
    </t:Table>
    <footer>
      <OverflowToolbar width="100%">
        <content>
          <ToolbarSpacer />
          <Button
              text="Imprimir"
              press="onPrintPressed"
              type="Accept"
              icon="sap-icon://print" />
        </content>
      </OverflowToolbar>
    </footer>
  </Page>
</mvc:View>