<View
    xmlns:mvc="sap.ui.core.mvc"
    controllerName="sps.wms.controller.configuracaowms"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:t="sap.ui.table"
    xmlns:l="sap.ui.layout"
    xmlns:u="sap.ui.unified"
    xmlns:f="sap.ui.layout.form">
  <Page
      id="pageView"
      busyIndicatorDelay="0"
      showHeader="true"
      title="Configurações WMS"
      showFooter="true"
      showNavButton="true"
      navButtonPress="onBack">
    <headerContent>
      <Button
          text="Sair"
          type="Up"
          icon="sap-icon://log"
          iconFirst="true"
          width="auto"
          enabled="true"
          visible="true"
          press="onLogout" />
    </headerContent>
    <content>
      <VBox id="vbx">
        
      </VBox>
    </content>
    <footer>
      <OverflowToolbar
          width="100%"
          height="46px">
        <content>
          <ToolbarSpacer />
          <Button
              press="onGravarPressed"
              text="Gravar"
              type="Accept"
              icon="sap-icon://accept" />
        </content>
      </OverflowToolbar>
    </footer>
  </Page>
</View>