<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    controllerName="sps.wms.controller.home"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:data="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
    xmlns:layout="sap.ui.layout"
    xmlns:f="sap.ui.layout.form"
    xmlns:t="sap.ui.table">
  <Page
      id="pageView"
      busyIndicatorDelay="0"
      showHeader="true"
      title="Portal de Etiquetas : {Data>/CompanyName}"
      showFooter="true"
      showNavButton="false"
      navButtonPress="onBack">
    <headerContent>
      <Toolbar class="sapMTBHeader-CTX">
        <Button
            text="Sair"
            type="Up"
            icon="sap-icon://log"
            iconFirst="true"
            width="auto"
            enabled="true"
            visible="true"
            press="onLogout" />
      </Toolbar>
    </headerContent>
    <VBox>
      <Title
          text="Configurações Sistema"
          titleStyle="H3"
          class="sapUiSmallMarginTop sapUiTinyMarginBegin"
          visible="{= ${Data>/Configura_Impressao} || ${Data>/Permissoes} || ${Data>/Fila_Impressao}}" />
      <FlexBox
          alignItems="Center"
          alignContent="Center"
          direction="Row"
          renderType="Bare"
          wrap="Wrap"
          width="100%"
          displayInline="true"
          fitContainer="true"
          visible="{= ${Data>/Configura_Impressao} || ${Data>/Permissoes} || ${Data>/Fila_Impressao}}">
        <items>
          <GenericTile
              visible="{Data>/Permissoes}"
              class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout"
              header="Permissões"
              press="onClickPermissoes">
            <TileContent>
              <ImageContent src="sap-icon://role" />
            </TileContent>
          </GenericTile>

          <GenericTile
              visible="{Data>/Configura_Impressao}"
              class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout"
              header="Configura Impressão"
              press="onClickConfiguraImpressao">
            <TileContent>
              <ImageContent src="sap-icon://developer-settings" />
            </TileContent>
          </GenericTile>

          <GenericTile
              visible="{Data>/Fila_Impressao}"
              class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout"
              header="Status Impressoras"
              press="onClickFilaImpressao">
            <TileContent>
              <ImageContent src="sap-icon://print" />
            </TileContent>
          </GenericTile>
        </items>
      </FlexBox>

      <Title
          text="Gestão"
          titleStyle="H3"
          class="sapUiSmallMarginTop sapUiTinyMarginBegin"
          visible="{Data>/Log_Impressao}" />
      <FlexBox
          alignItems="Center"
          alignContent="Center"
          direction="Row"
          renderType="Bare"
          wrap="Wrap"
          width="100%"
          displayInline="true"
          fitContainer="true"
          visible="{Data>/Log_Impressao}">
        <items>
          <GenericTile
              visible="{Data>/Log_Impressao}"
              class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout"
              header="Auditoria de Impressões"
              press="onClickLogImpressao">
            <TileContent>
              <ImageContent src="sap-icon://history" />
            </TileContent>
          </GenericTile>
        </items>
      </FlexBox>
      <Title
          text="Impressão"
          titleStyle="H3"
          class="sapUiSmallMarginTop sapUiTinyMarginBegin"
          visible="{= ${Data>/Etiqueta_Volume} || ${Data>/Etiqueta_Palete} || ${Data>/Etiqueta_Expedicao}}" />
      <FlexBox
          alignItems="Center"
          alignContent="Center"
          direction="Row"
          renderType="Bare"
          wrap="Wrap"
          width="100%"
          displayInline="true"
          fitContainer="true"
          visible="{= ${Data>/Etiqueta_Volume} || ${Data>/Etiqueta_Palete} || ${Data>/Etiqueta_Expedicao} || ${Data>/Etiqueta_Manual}}">
        <items>
          <GenericTile
              visible="{Data>/Etiqueta_Volume}"
              class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout"
              header="Impressão Etiqueta"
              press="onClickEtiquetaVolume">
            <TileContent>
              <ImageContent src="sap-icon://print" />
            </TileContent>
          </GenericTile>

          <GenericTile
              visible="{Data>/Etiqueta_Manual}"
              class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout"
              header="Etiqueta Manual"
              press="onClickEtiquetaManual">
            <TileContent>
              <ImageContent src="sap-icon://customer-and-supplier" />
            </TileContent>
          </GenericTile>

        </items>
      </FlexBox>

    </VBox>
  </Page>
</mvc:View>