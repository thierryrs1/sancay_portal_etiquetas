<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  xmlns:data="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
  xmlns:l="sap.ui.layout"
  xmlns:f="sap.ui.layout.form"
  >
  <Dialog title="Nova rota">
    <VBox class="sapUiSmallMargin" height="auto">
      <OverflowToolbar width="100%" height="60px" >
        <content>
          <HBox
              alignContent="Center"
              alignItems="Center">
            <Label text="Nome da Rota"
              class="sapUiSmallMarginBeginEnd"/>
            <Input value="{Data>/nomeNovaRota}"/>
          </HBox>
          <ToolbarSpacer />
          <Button text="Ok" press="onConfirmNomeRotaClick" type="Accept" icon="sap-icon://save"/>
          <Button text="Cancela" press="onCancelaNomeRotaClick" type="Cancel" icon="sap-icon://cancel"/>
        </content>
      </OverflowToolbar>
    </VBox>
  </Dialog>
</core:FragmentDefinition>